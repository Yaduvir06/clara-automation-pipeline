{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["agent_name", "version", "system_prompt"],
  "properties": {
    "agent_name": {
      "type": "string",
      "description": "Display name for the Retell agent"
    },
    "account_id": {
      "type": "string",
      "description": "Links back to account memo"
    },
    "version": {
      "type": "string",
      "enum": ["v1", "v2"]
    },
    "voice_style": {
      "type": "string",
      "description": "Voice characteristics: professional, warm, efficient",
      "default": "professional and helpful"
    },
    "system_prompt": {
      "type": "string",
      "description": "The full conversational prompt for the AI agent"
    },
    "business_hours": {
      "type": ["object", "null"],
      "description": "Copy from account memo for reference"
    },
    "emergency_routing": {
      "type": ["object", "null"],
      "description": "Copy from account memo for reference"
    },
    "transfer_timeout_seconds": {
      "type": "integer",
      "default": 60
    },
    "fallback_protocol": {
      "type": "string",
      "description": "What to do if transfer fails"
    },
    "metadata": {
      "type": "object",
      "properties": {
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "updated_at": {
          "type": "string",
          "format": "date-time"
        },
        "source": {
          "type": "string",
          "enum": ["demo_call", "onboarding_call", "onboarding_form"]
        }
      }
    }
  }
}